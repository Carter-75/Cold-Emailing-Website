{
  "experimentalServices": {
    "frontend": {
      "entrypoint": "frontend",
      "routePrefix": "/",
      "framework": "angular"
    },
    "backend": {
      "entrypoint": "backend",
      "routePrefix": "/_/backend"
    }
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/_/backend/api/:path*"
    },
    {
      "source": "/auth/:path*",
      "destination": "/_/backend/api/auth/:path*"
    },
    {
      "source": "/((?!api/|auth/|_/backend/).*)",
      "destination": "/index.html"
    }
  ]
}
