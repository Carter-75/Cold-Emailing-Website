{
  "version": 2,
  "builds": [
    {
      "src": "backend/bin/www",
      "use": "@vercel/node"
    },
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist/frontend"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/auth/(.*)",
      "dest": "backend/bin/www"
    },
    {
      "src": "/api/(.*)",
      "dest": "backend/bin/www"
    },
    {
      "src": "/socket.io/(.*)",
      "dest": "backend/bin/www"
    },
    {
      "src": "/dashboard",
      "dest": "/index.html"
    },
    {
      "src": "/(assets/.*)",
      "dest": "/$1"
    },
    {
      "src": "/(.*\\.(js|css|png|jpg|svg|ico))$",
      "dest": "/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
