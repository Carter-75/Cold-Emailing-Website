{
  "experimentalServices": {
    "frontend": {
      "entrypoint": "frontend",
      "routePrefix": "/",
      "outputDirectory": "dist/frontend"
    },
    "backend": {
      "entrypoint": "backend",
      "routePrefix": "/_/backend"
    }
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/_/backend/api/:path*"
    },
    {
      "source": "/auth/:path*",
      "destination": "/_/backend/api/auth/:path*"
    },
    {
      "source": "/dashboard",
      "destination": "/"
    },
    {
      "source": "/login",
      "destination": "/"
    }
  ]
}
